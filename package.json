{
  "name": "@luvabase/cli",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Command line tool for Luvabase",
  "scripts": {
    "build": "tsc",
    "publish": "npm run new-version && npm run build && npm publish --access=public",
    "new-version": "npm --no-git-tag-version version patch"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.3.8",
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "luva": "dist/bin.js"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
